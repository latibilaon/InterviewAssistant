# ===============================
# Interview Assistant 发布版配置
# 复制为 app/.env 后按需修改
# ===============================

# ---- LLM 连接（设置页也可配置） ----
LLM_PROVIDER=OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-pro
OPENROUTER_CUSTOM_MODELS=google/gemini-2.5-pro,google/gemini-3.1-pro-preview,google/gemini-3-flash-preview
OPENROUTER_REASONING_EFFORT=minimal
OPENROUTER_WEB_PLUGIN_ENABLED=true

# ---- 语言 / 转录 ----
STT_MODE=local
STT_LANGUAGE_PROFILE=auto
STT_DEFAULT_LANGUAGE=zh
STT_ALLOWED_LANGUAGES=zh,en
WHISPER_LANGUAGE=
WHISPER_LOCAL_MODEL=small
AUTO_ANSWER_ENABLED=false
TRANSCRIPT_MAX_ITEMS=600

# ---- 音频设备（可在设置页保存） ----
AUDIO_DEVICE_INDEX=
AUDIO_DEVICE_NAME=

# ---- LLM 生成参数 ----
LLM_STREAMING=true
LLM_TEMPERATURE=0.35
LLM_MAX_TOKENS=1400
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
LLM_MIN_ANSWER_CHARS=220

# ---- Web / RAG（默认关闭RAG，保证启动快） ----
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=3
RAG_ENABLED=false
RAG_FORCE_REBUILD=false
RAG_NON_BLOCKING_STARTUP=true
RAG_TOP_K=4

# 注意：以下相对路径以“应用根目录”为基准
DOCS_DIR=./data/docs
INDEX_DIR=./data/index
